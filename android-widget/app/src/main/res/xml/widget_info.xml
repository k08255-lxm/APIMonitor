<?xml version="1.0" encoding="utf-8"?>
<!-- WorkManager owns periodic network refreshes to avoid launcher-specific polling. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:configure="com.apimonitor.widget.MainActivity"
    android:description="@string/widget_description"
    android:initialLayout="@layout/widget_dashboard"
    android:minHeight="320dp"
    android:minWidth="250dp"
    android:previewImage="@drawable/ic_app"
    android:resizeMode="horizontal|vertical"
    android:targetCellHeight="5"
    android:targetCellWidth="4"
    android:updatePeriodMillis="0"
    android:widgetCategory="home_screen" />
