<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="24dp"
        android:paddingRight="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/config_title"
            android:textColor="@color/ink"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/config_subtitle"
            android:textColor="@color/muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/config_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="@string/no_widgets_message"
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/config_add_widget"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/widget_button"
            android:text="@string/add_widget"
            android:textAllCaps="false"
            android:textColor="@color/teal"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/config_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/config_url_label"
            android:textColor="@color/ink"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/config_url"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:autofillHints="url"
            android:background="@drawable/widget_metric"
            android:hint="@string/config_url_hint"
            android:inputType="textUri"
            android:maxLines="1"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/config_username_label"
            android:textColor="@color/ink"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/widget_metric"
            android:gravity="center_vertical"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:text="@string/config_username_value"
            android:textColor="@color/ink"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/config_password_label"
            android:textColor="@color/ink"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/config_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:autofillHints="password"
            android:background="@drawable/widget_metric"
            android:hint="@string/config_password_hint"
            android:inputType="textPassword"
            android:maxLines="1"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/config_security_note"
            android:textColor="@color/muted"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/config_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="@color/status_muted"
            android:textSize="13sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/config_test"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/widget_button"
                android:text="@string/config_test"
                android:textAllCaps="false"
                android:textColor="@color/teal" />

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/config_save"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/widget_button"
                android:text="@string/config_save"
                android:textAllCaps="false"
                android:textColor="@color/teal"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/config_cancel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/transparent"
            android:text="@string/config_cancel"
            android:textAllCaps="false"
            android:textColor="@color/muted" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
