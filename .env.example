# 服务端默认只监听本机回环地址。只有在可信局域网中才使用 0.0.0.0。
HOST=127.0.0.1
PORT=8787

# 只要 HOST 可被其他设备访问，就建议设置此密码。浏览器会显示标准登录框，用户名为
# monitor，密码就是这里的值。
# DASHBOARD_PASSWORD=replace-with-a-long-random-value

# 可选的 OpenAI 兼容反向代理。把客户端 Base URL 指向本服务的 /v1 路径即可。未设置
# 上游密钥时，Authorization 会透传，但不会写入日志。
UPSTREAM_BASE_URL=https://api.openai.com
# UPSTREAM_API_KEY=sk-...
# 当非回环地址绑定使用服务端上游密钥时必须设置。客户端调用本监控服务时使用此值作为
# API 密钥，服务会将它替换为上游密钥。
# PROXY_TOKEN=replace-with-a-long-random-value

# POST /api/events 可选的 Bearer token。
# INGEST_TOKEN=replace-with-a-long-random-value

# Sub2API 管理员连接器。在 Sub2API 设置中生成 Admin API Key。
# SUB2API_BASE_URL=https://sub2api.example.com
# SUB2API_ADMIN_KEY=replace-with-sub2api-admin-key
# SUB2API_SCOPE=admin
# 也可以只监测一个 Sub2API 用户，并使用 JWT：
# SUB2API_SCOPE=user
# SUB2API_TOKEN=replace-with-user-jwt
# SUB2API_TIMEZONE=Asia/Hong_Kong

# cc-switch 默认自动检测 ~/.cc-switch/cc-switch.db，需要时可覆盖路径。
# CC_SWITCH_ENABLED=false 可在启动时关闭；运行中也可以在面板设置里修改。
# CC_SWITCH_ENABLED=true
# CC_SWITCH_DB_PATH=C:\Users\you\.cc-switch\cc-switch.db

# 事件持久化和连接器刷新行为。
DATA_DIR=data
CONNECTOR_CACHE_SECONDS=10
CONNECTOR_TIMEOUT_MS=5000
